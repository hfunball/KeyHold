<Window x:Class="KeyHold.StartupSplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360"
        Height="118"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        WindowStyle="None">
    <Border Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Width="42" Height="42" Margin="0,0,12,0">
                <Border Background="#171B22"
                        BorderBrush="#29313D"
                        BorderThickness="1"
                        CornerRadius="8" />
                <Border Width="22"
                        Height="24"
                        VerticalAlignment="Center"
                        Background="#242932"
                        CornerRadius="5" />
                <Path Data="M 11 28 L 31 28 L 28 34 L 14 34 Z"
                      Fill="#101318" />
                <Border Width="20"
                        Height="5"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,7"
                        Background="{DynamicResource AccentBrush}"
                        CornerRadius="2.5" />
                <Border Width="12"
                        Height="3"
                        VerticalAlignment="Center"
                        Margin="0,-5,0,0"
                        Background="#F5F7FA"
                        CornerRadius="1.5" />
            </Grid>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="KeyHold is running"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" />
                <TextBlock Text="Use the tray icon near the clock to open the app, release keys, or exit."
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <ProgressBar Grid.Row="1"
                         Grid.ColumnSpan="2"
                         x:Name="DismissProgress"
                         Height="3"
                         Margin="0,12,0,0"
                         Maximum="100"
                         Value="100"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="#26303D"
                         BorderThickness="0" />
        </Grid>
    </Border>
</Window>
